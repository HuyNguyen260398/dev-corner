{
  "name": "dev-corner",
  "version": "0.1.0",
  "description": "A fully local Chrome MV3 extension that crawls saved blog sources and shows a daily 5-post digest.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  }
}
