{
  "name": "dev-corner",
  "version": "0.1.0",
  "description": "A fully local Chrome MV3 extension that crawls saved blog sources and shows a daily 5-post digest.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "lint": "eslint .",
    "verify:package": "node scripts/verify-package.mjs",
    "verify:release": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm verify:package"
  },
  "dependencies": {
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "linkedom": "^0.18.12",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.1.43",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
